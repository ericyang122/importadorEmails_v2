# Modelo de configuracao. Copie para .env e preencha. O .env NAO sobe pro git.

# --- Credenciais do Sigavi (usadas via linha de comando; a interface pede na tela) ---
SIGAVI_LOGIN=seu.email@abyara.com.br
SIGAVI_SENHA=sua_senha

# --- Tela web (app.py) ---
APP_PASSWORD=uma_senha_forte
APP_SECRET_KEY=uma_chave_grande_aleatoria
SESSION_COOKIE_SECURE=false        # use true quando acessar apenas pelo HTTPS do ngrok
NGROK_URL=                         # opcional: dominio fixo, ex. https://nome.ngrok-free.dev

# --- Desempenho ---
SIGAVI_CONSULTA_WORKERS=8       # buscas de email simultaneas
SIGAVI_CONSULTA_TENTATIVAS=3    # retentativas em resposta suspeita
SIGAVI_CONSULTA_BACKOFF=1.5     # pausa base (s) entre retentativas
SIGAVI_CADASTRO_DELAY=1.0       # fator de velocidade do cadastro (0.6 = mais rapido)

# --- Notificacao por WhatsApp (opcional, Evolution API) ---
# Deixe em branco para desativar.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
WHATSAPP_DESTINO=                  # quem recebe (DDI+DDD+numero); varios separados por virgula

SIGAVI_EMPREENDIMENTO=arvo            # empreendimento buscado no modal "Imovel de origem" do cadastro
