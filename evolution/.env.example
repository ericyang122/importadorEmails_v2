# Copie este arquivo para .env (na mesma pasta) e preencha os valores.
# O .env real é ignorado pelo git — nunca comite segredos.
# O docker compose lê automaticamente o .env desta pasta.

# Chave de autenticação da Evolution API.
# Gere uma aleatória, ex.: openssl rand -hex 24
# Use a MESMA chave em EVOLUTION_API_KEY no .env do importador.
EVOLUTION_API_KEY=troque-por-uma-chave-aleatoria

# Senha do Postgres da Evolution.
# Atenção: a senha só é aplicada na PRIMEIRA criação do volume do banco.
# Se já existe um volume, mantenha a senha original ou recrie o volume.
POSTGRES_PASSWORD=defina-uma-senha
